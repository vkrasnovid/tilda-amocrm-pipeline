# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-32-bytes-hex-random-here
LOG_LEVEL=INFO

# ── Webhook security ──────────────────────────────────────────────────────────
TILDA_WEBHOOK_SECRET=change-me-tilda-shared-secret

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=change-me-admin-bearer-token

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/db.sqlite3

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── AmoCRM ────────────────────────────────────────────────────────────────────
AMOCRM_BASE_URL=https://your-subdomain.amocrm.ru
AMOCRM_CLIENT_ID=change-me-oauth2-client-id
AMOCRM_CLIENT_SECRET=change-me-oauth2-client-secret
AMOCRM_REDIRECT_URI=https://your-domain.com/oauth2/callback
AMOCRM_ACCESS_TOKEN=change-me-access-token
AMOCRM_REFRESH_TOKEN=change-me-refresh-token
AMOCRM_PIPELINE_ID=0
AMOCRM_STAGE_ID=0

# ── SMTP (outgoing email) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM_NAME=Company Name
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# ── IMAP (incoming email polling) ─────────────────────────────────────────────
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=noreply@example.com
IMAP_PASSWORD=change-me-imap-password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=300

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=change-me-bot-token
TELEGRAM_MANAGER_CHAT_ID=0
